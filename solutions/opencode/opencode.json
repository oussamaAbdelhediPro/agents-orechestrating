{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "instructions": [
    "AGENTS.md"
  ],
  "agent": {
    "build": {
      "permission": {
        "bash": "ask"
      }
    },
    "orchestrator": {
      "permission": {
        "task": {
          "*": "allow"
        },
        "bash": "deny",
        "write": "deny",
        "edit": "deny"
      }
    }
  }
}
